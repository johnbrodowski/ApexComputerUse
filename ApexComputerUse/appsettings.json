{
  // ApexComputerUse deployment configuration.
  // Values here serve as machine-level defaults.
  // User preferences (model paths, API key) stored in %APPDATA%\ApexComputerUse\settings.json
  // take priority in the GUI and will override these when the app is running interactively.
  //
  // Any value can also be set via an APEX_* environment variable (highest priority):
  //   APEX_HTTP_PORT, APEX_HTTP_BIND_ALL, APEX_PIPE_NAME, APEX_LOG_LEVEL,
  //   APEX_ENABLE_SHELL_RUN, APEX_MODEL_PATH, APEX_MMPROJ_PATH,
  //   APEX_API_KEY, APEX_ALLOWED_CHAT_IDS, APEX_TELEGRAM_TOKEN

  "HttpPort": 8081,
  "HttpBindAll": false,
  "PipeName": "ApexComputerUse",
  "LogLevel": "Information",
  "EnableShellRun": true,
  "ModelPath": "",
  "MmProjPath": "",
  "ApiKey": "",
  "AllowedChatIds": "",
  "TelegramToken": ""
}
