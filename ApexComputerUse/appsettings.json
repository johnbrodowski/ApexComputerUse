{
  // ApexComputerUse deployment configuration.
  // Values here serve as machine-level defaults (deployment / CI / headless scenarios).
  // Any value can also be set via an APEX_* environment variable (highest priority):
  //   APEX_HTTP_PORT, APEX_HTTP_BIND_ALL, APEX_HTTP_AUTOSTART, APEX_PIPE_NAME, APEX_LOG_LEVEL,
  //   APEX_ENABLE_SHELL_RUN, APEX_MODEL_PATH, APEX_MMPROJ_PATH,
  //   APEX_API_KEY, APEX_ALLOWED_CHAT_IDS, APEX_TELEGRAM_TOKEN
  //
  // User preferences (ModelPath, MmProjPath, ApiKey, AllowedChatIds) are stored in
  //   %APPDATA%\ApexComputerUse\settings.json   - GUI preferences
  //   %APPDATA%\ApexComputerUse\ai-settings.json - AI provider credentials

  "HttpPort": 8080,
  "HttpBindAll": false,
  "HttpAutoStart": true,
  "PipeName": "ApexComputerUse",
  "LogLevel": "Information",
  "EnableShellRun": false,
  "EnableFileIo": false,
  // List of directories that /file requests must resolve within (defense-in-depth alongside
  // path canonicalization). Empty = fail-closed (refuse all paths even if EnableFileIo=true).
  // Example: ["C:\\Users\\me\\projects", "D:\\src"]
  "FileIoAllowedRoots": [],
  "TelegramToken": "",
  "TestRunnerExePath": "",
  "TestRunnerConfigPath": ""
}

