                                <Paragraph>
                                    <Run Foreground="#FF4FC3F7">[2026-03-25 11:00:06]</Run>
                                    <Run Foreground="#FF81C784"> [INFO ] </Run>
                                    <Run>[System       ] Health check passed (5/5 services)</Run>
                                </Paragraph>
                                <Paragraph>
                                    <Run Foreground="#FF4FC3F7">[2026-03-25 11:00:10]</Run>
                                    <Run Foreground="#FFFFB74D"> [WARN ] </Run>
                                    <Run>[PaymentGateway] Latency spike: 445ms (avg: 145ms)</Run>
                                </Paragraph>
                            </FlowDocument>
                        </RichTextBox>
                    </DockPanel>
                </Grid>
            </TabItem>

            <!-- ── TAB 7: DISPLAY ────────────────────────────────────────── -->
            <TabItem Header="Display" AutomationProperties.AutomationId="TabDisplay">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <WrapPanel Margin="10" ItemWidth="320">

                        <!-- TextBlock styles -->
                        <GroupBox Header="TextBlock Styles" Margin="0,0,10,10" Width="310">
                            <StackPanel Margin="8">
                                <TextBlock Text="Normal TextBlock"/>
                                <TextBlock Text="Bold TextBlock"              FontWeight="Bold"/>
                                <TextBlock Text="Italic TextBlock"            FontStyle="Italic" Foreground="Gray"/>
                                <TextBlock Text="Large Heading"               FontSize="16" FontWeight="Bold" Foreground="DarkBlue"/>
                                <TextBlock Text="Warning Text"                FontWeight="Bold" Foreground="DarkOrange"/>
                                <TextBlock Text="Error Text"                  FontWeight="Bold" Foreground="Red"/>
                                <TextBlock Text="Success Text"                FontWeight="Bold" Foreground="Green"/>
                                <TextBlock TextDecorations="Strikethrough"    Text="Strikethrough Text"  Foreground="Gray"/>
                                <TextBlock TextDecorations="Underline"        Text="Underlined Text"     Foreground="Navy"/>
                                <TextBlock Text="Consolas Monospace" FontFamily="Consolas" FontSize="11" Background="#FFF0F0F0" Padding="3"/>
                                <TextBlock Margin="0,6,0,0">
                                    <Run Text="Mixed " FontWeight="Bold"/>
                                    <Run Text="inline " FontStyle="Italic" Foreground="SteelBlue"/>
                                    <Run Text="runs " TextDecorations="Underline" Foreground="Purple"/>
                                    <Run Text="in one block"/>
                                </TextBlock>
                            </StackPanel>
                        </GroupBox>

                        <!-- Hyperlinks -->
                        <GroupBox Header="Hyperlinks" Margin="0,0,10,10" Width="310">
                            <StackPanel Margin="8">
                                <TextBlock Margin="0,4">
                                    <Hyperlink AutomationProperties.AutomationId="DocLink">Visit documentation portal</Hyperlink>
                                </TextBlock>
                                <TextBlock Margin="0,4">
                                    GitHub —
                                    <Hyperlink AutomationProperties.AutomationId="GithubLink">ApexUIBridge</Hyperlink>
                                    — MIT License
                                </TextBlock>
                                <TextBlock Margin="0,4">
                                    <Hyperlink AutomationProperties.AutomationId="SupportLink">support@company.com</Hyperlink>
                                </TextBlock>
                                <TextBlock Margin="0,4">
                                    <Hyperlink IsEnabled="False" AutomationProperties.AutomationId="DisabledLink">Disabled hyperlink</Hyperlink>
                                </TextBlock>
                            </StackPanel>
                        </GroupBox>

                        <!-- ProgressBars + Indeterminate -->
                        <GroupBox Header="Progress Bars" Margin="0,0,10,10" Width="310">
                            <StackPanel Margin="8">
                                <TextBlock Text="CPU:" Margin="0,0,0,2"/>
                                <ProgressBar Value="72"          Height="16" Margin="0,0,0,6" AutomationProperties.AutomationId="PbCpu"/>
                                <TextBlock Text="RAM:" Margin="0,0,0,2"/>
                                <ProgressBar Value="55"          Height="16" Margin="0,0,0,6" AutomationProperties.AutomationId="PbRam"/>
                                <TextBlock Text="Disk:" Margin="0,0,0,2"/>
                                <ProgressBar Value="88"          Height="16" Margin="0,0,0,6" Foreground="OrangeRed" AutomationProperties.AutomationId="PbDisk"/>
                                <TextBlock Text="Network:" Margin="0,0,0,2"/>
                                <ProgressBar Value="34"          Height="16" Margin="0,0,0,6" AutomationProperties.AutomationId="PbNet"/>
                                <TextBlock Text="Indeterminate (loading):" Margin="0,0,0,2"/>
                                <ProgressBar IsIndeterminate="True" Height="16" AutomationProperties.AutomationId="PbIndeterminate"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Borders / visual states -->
                        <GroupBox Header="Borders &amp; Visual States" Margin="0,0,10,10" Width="310">
                            <StackPanel Margin="8">
                                <Border BorderBrush="Gray"       BorderThickness="1"    Padding="6" Margin="0,3" CornerRadius="0">
                                    <TextBlock Text="Flat border (1px gray)"/>
                                </Border>
                                <Border BorderBrush="SteelBlue"  BorderThickness="2"    Padding="6" Margin="0,3" CornerRadius="4">
                                    <TextBlock Text="Rounded border (4px, 2px blue)"/>
                                </Border>
                                <Border Background="LightYellow" BorderBrush="Goldenrod" BorderThickness="1" Padding="6" Margin="0,3">
                                    <TextBlock Text="Warning style border" Foreground="DarkGoldenrod" FontWeight="Bold"/>
                                </Border>
                                <Border Background="#FFFFE8E8"   BorderBrush="Red"       BorderThickness="1" Padding="6" Margin="0,3">
                                    <TextBlock Text="Error style border" Foreground="DarkRed" FontWeight="Bold"/>
                                </Border>
                                <Border Background="#FFE8FFE8"   BorderBrush="Green"     BorderThickness="1" Padding="6" Margin="0,3">
                                    <TextBlock Text="Success style border" Foreground="DarkGreen" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                        </GroupBox>

                        <!-- Disabled / IsEnabled states -->
                        <GroupBox Header="Control States" Margin="0,0,10,10" Width="310">
                            <Grid Margin="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormLabel}" Text="Disabled TextBox:"/>
                                <TextBox   Grid.Row="0" Grid.Column="1" Text="Cannot edit" IsEnabled="False" Margin="0,2" AutomationProperties.AutomationId="DisabledTextBox"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FormLabel}" Text="ReadOnly TextBox:"/>
                                <TextBox   Grid.Row="1" Grid.Column="1" Text="Read only"   IsReadOnly="True" Margin="0,2" AutomationProperties.AutomationId="ReadOnlyTextBox"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FormLabel}" Text="Disabled Button:"/>
                                <Button    Grid.Row="2" Grid.Column="1" Content="Disabled" IsEnabled="False" Margin="0,2" AutomationProperties.AutomationId="DisabledButton"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FormLabel}" Text="Disabled CheckBox:"/>
                                <CheckBox  Grid.Row="3" Grid.Column="1" Content="Disabled (on)" IsChecked="True" IsEnabled="False" Margin="0,2" AutomationProperties.AutomationId="DisabledCheckBox"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource FormLabel}" Text="Disabled ComboBox:"/>
                                <ComboBox  Grid.Row="4" Grid.Column="1" IsEnabled="False" Margin="0,2" AutomationProperties.AutomationId="DisabledComboBox">
                                    <ComboBoxItem>Disabled item</ComboBoxItem>
                                </ComboBox>
                                <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource FormLabel}" Text="Disabled Slider:"/>
                                <Slider    Grid.Row="5" Grid.Column="1" Value="60" IsEnabled="False" Margin="0,2" AutomationProperties.AutomationId="DisabledSlider"/>
                            </Grid>
                        </GroupBox>

                    </WrapPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── TAB 8: WPF SPECIFICS ──────────────────────────────────── -->
            <TabItem Header="WPF" AutomationProperties.AutomationId="TabWpf">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <WrapPanel Margin="10">

                        <!-- Expanders -->
                        <GroupBox Header="Expander" Width="340" Margin="0,0,10,10">
                            <StackPanel Margin="6">
                                <Expander Header="▶ Server Configuration" IsExpanded="True" AutomationProperties.AutomationId="ExpanderServer">
                                    <StackPanel Margin="16,4,4,4">
                                        <CheckBox Content="Enable HTTP/2"        IsChecked="True"  Margin="0,2"/>
                                        <CheckBox Content="Enable QUIC (HTTP/3)" Margin="0,2"/>
                                        <CheckBox Content="Force HTTPS redirect" IsChecked="True"  Margin="0,2"/>
                                    </StackPanel>
                                </Expander>
                                <Expander Header="▶ Logging Options" Margin="0,4,0,0" AutomationProperties.AutomationId="ExpanderLogging">
                                    <StackPanel Margin="16,4,4,4">
                                        <CheckBox Content="Structured logging (JSON)" IsChecked="True" Margin="0,2"/>
                                        <CheckBox Content="Log request bodies"        Margin="0,2"/>
                                        <CheckBox Content="Async log writer"          IsChecked="True" Margin="0,2"/>
                                    </StackPanel>
                                </Expander>
                                <Expander Header="▶ Feature Flags (collapsed)" Margin="0,4,0,0" AutomationProperties.AutomationId="ExpanderFeatures">
                                    <StackPanel Margin="16,4,4,4">
                                        <CheckBox Content="Dark Mode"    Margin="0,2"/>
                                        <CheckBox Content="Beta UI"      Margin="0,2"/>
                                        <CheckBox Content="A/B Testing"  Margin="0,2"/>
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </GroupBox>

                        <!-- ToggleButton + RepeatButton + Thumb -->
                        <GroupBox Header="Button Variants" Width="280" Margin="0,0,10,10">
                            <StackPanel Margin="6">
                                <TextBlock Text="ToggleButton:" Margin="0,0,0,2"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <ToggleButton Content="Toggle OFF" Width="110" AutomationProperties.AutomationId="Toggle1" Margin="0,0,6,0"/>
                                    <ToggleButton Content="Toggle ON"  Width="110" IsChecked="True" AutomationProperties.AutomationId="Toggle2"/>
                                </StackPanel>
                                <TextBlock Text="RepeatButton (hold to fire):" Margin="0,0,0,2"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <RepeatButton Content="◀◀ Hold" Width="90" Interval="200" AutomationProperties.AutomationId="RepeatLeft" Margin="0,0,6,0"/>
                                    <RepeatButton Content="Hold ▶▶" Width="90" Interval="200" AutomationProperties.AutomationId="RepeatRight"/>
                                </StackPanel>
                                <TextBlock Text="Thumb (draggable handle):" Margin="0,0,0,2"/>
                                <Thumb Width="60" Height="20" Background="SteelBlue" AutomationProperties.AutomationId="DragThumb"/>
                                <TextBlock Text="CheckBox variants:" Margin="0,8,0,2"/>
                                <CheckBox Content="Normal (unchecked)"  AutomationProperties.AutomationId="CbNormal"    Margin="0,2"/>
                                <CheckBox Content="Checked"             IsChecked="True" AutomationProperties.AutomationId="CbChecked"   Margin="0,2"/>
                                <CheckBox Content="Indeterminate"       IsChecked="{x:Null}" IsThreeState="True" AutomationProperties.AutomationId="CbIndet" Margin="0,2"/>
                                <CheckBox Content="Disabled (checked)"  IsChecked="True" IsEnabled="False" AutomationProperties.AutomationId="CbDisabled" Margin="0,2"/>
                            </StackPanel>
                        </GroupBox>

                        <!-- Popup demo -->
                        <GroupBox Header="Popup" Width="280" Margin="0,0,10,10">
                            <StackPanel Margin="6">
                                <TextBlock Text="Click the button to open a Popup:" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                <ToggleButton x:Name="PopupToggle" Content="Open Popup ▾"
                                              Width="140" HorizontalAlignment="Left"
                                              AutomationProperties.AutomationId="PopupToggleBtn"/>
                                <Popup IsOpen="{Binding IsChecked, ElementName=PopupToggle}"
                                       PlacementTarget="{Binding ElementName=PopupToggle}"
                                       Placement="Bottom" StaysOpen="False"
                                       AutomationProperties.AutomationId="TorturePopup">
                                    <Border Background="White" BorderBrush="#FFAAAAAA" BorderThickness="1"
                                            Padding="12" Width="220">
                                        <StackPanel>
                                            <TextBlock Text="Popup Menu" FontWeight="Bold" Margin="0,0,0,6"/>
                                            <CheckBox  Content="Option A" IsChecked="True" Margin="0,2" AutomationProperties.AutomationId="PopupOptA"/>
                                            <CheckBox  Content="Option B" Margin="0,2" AutomationProperties.AutomationId="PopupOptB"/>
                                            <CheckBox  Content="Option C" Margin="0,2" AutomationProperties.AutomationId="PopupOptC"/>
                                            <Separator Margin="0,6"/>
                                            <Button Content="Apply &amp; Close" AutomationProperties.AutomationId="PopupApply"/>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                                <TextBlock Text="Context menu (right-click below):" Margin="0,16,0,4" TextWrapping="Wrap"/>
                                <Border Background="#FFF0F4FF" BorderBrush="#FFAACCFF" BorderThickness="1" Padding="10" Height="50">
                                    <Border.ContextMenu>
                                        <ContextMenu AutomationProperties.AutomationId="BorderContextMenu">
                                            <MenuItem Header="Copy"        AutomationProperties.AutomationId="CtxCopy"/>
                                            <MenuItem Header="Paste"       AutomationProperties.AutomationId="CtxPaste"/>
                                            <Separator/>
                                            <MenuItem Header="Properties" AutomationProperties.AutomationId="CtxProps"/>
                                            <MenuItem Header="Sub-menu">
                                                <MenuItem Header="Sub-item A"/>
                                                <MenuItem Header="Sub-item B"/>
                                                <MenuItem Header="Sub-item C"/>
                                            </MenuItem>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    <TextBlock Text="Right-click for ContextMenu" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="SteelBlue"/>
                                </Border>
                            </StackPanel>
                        </GroupBox>

                        <!-- InkCanvas -->
                        <GroupBox Header="InkCanvas (draw with mouse)" Width="340" Margin="0,0,10,10">
                            <StackPanel Margin="6">
                                <Border BorderBrush="Gray" BorderThickness="1">
                                    <InkCanvas x:Name="TortureInkCanvas" Height="150" Background="White"
                                               AutomationProperties.AutomationId="TortureInkCanvas"/>
                                </Border>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <Button Content="Clear Ink" Width="90" Margin="0,0,6,0" Click="OnClearInk" AutomationProperties.AutomationId="ClearInkBtn"/>
                                    <TextBlock Text="Ink mode:" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <ComboBox Width="100" SelectedIndex="0" AutomationProperties.AutomationId="InkMode">
                                        <ComboBoxItem>Ink (draw)</ComboBoxItem>
                                        <ComboBoxItem>Erase by point</ComboBoxItem>
                                        <ComboBoxItem>Erase by stroke</ComboBoxItem>
                                        <ComboBoxItem>Select</ComboBoxItem>
                                        <ComboBoxItem>None</ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </GroupBox>

                        <!-- Nested TabControl -->
                        <GroupBox Header="Nested TabControl" Width="320" Margin="0,0,10,10">
                            <TabControl Height="160" Margin="4" AutomationProperties.AutomationId="NestedTabs">
                                <TabItem Header="Sub A" AutomationProperties.AutomationId="SubTabA">
                                    <StackPanel Margin="6">
                                        <TextBox Text="Field in sub-tab A" Margin="0,3" AutomationProperties.AutomationId="SubTabAField"/>
                                        <CheckBox Content="Sub-tab A option" IsChecked="True" AutomationProperties.AutomationId="SubTabACb"/>
                                    </StackPanel>
                                </TabItem>
                                <TabItem Header="Sub B" AutomationProperties.AutomationId="SubTabB">
                                    <StackPanel Margin="6">
                                        <Slider Minimum="0" Maximum="100" Value="42" Margin="0,3" AutomationProperties.AutomationId="SubTabBSlider"/>
                                        <ProgressBar Value="42" Height="14" AutomationProperties.AutomationId="SubTabBPb"/>
                                    </StackPanel>
                                </TabItem>
                                <TabItem Header="Sub C" AutomationProperties.AutomationId="SubTabC">
                                    <ListBox Margin="4" AutomationProperties.AutomationId="SubTabCList">
                                        <ListBoxItem>Nested item 1</ListBoxItem>
                                        <ListBoxItem>Nested item 2</ListBoxItem>
                                        <ListBoxItem>Nested item 3</ListBoxItem>
                                    </ListBox>
                                </TabItem>
                            </TabControl>
                        </GroupBox>

                    </WrapPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ── TAB 9: DIALOGS ────────────────────────────────────────── -->
            <TabItem Header="Dialogs" AutomationProperties.AutomationId="TabDialogs">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12">
                        <GroupBox Header="Standard Dialog Launchers" Margin="0,0,0,12">
                            <WrapPanel Margin="8">
                                <Button Content="Open File..."    Width="140" Height="34" Margin="4" Click="OnOpenFile"    AutomationProperties.AutomationId="DlgOpenFile"/>
                                <Button Content="Save File..."    Width="140" Height="34" Margin="4" Click="OnSaveFile"    AutomationProperties.AutomationId="DlgSaveFile"/>
                                <Button Content="Browse Folder.." Width="140" Height="34" Margin="4" Click="OnBrowseFolder" AutomationProperties.AutomationId="DlgFolder"/>
                                <Button Content="Choose Font..."  Width="140" Height="34" Margin="4" Click="OnChooseFont"  AutomationProperties.AutomationId="DlgFont"/>
                                <Button Content="Choose Color..." Width="140" Height="34" Margin="4" Click="OnChooseColor" AutomationProperties.AutomationId="DlgColor"/>
                                <Button Content="MessageBox Info"    Width="140" Height="34" Margin="4" Click="OnMsgInfo"    AutomationProperties.AutomationId="DlgMsgInfo"/>
                                <Button Content="MessageBox Warning" Width="140" Height="34" Margin="4" Click="OnMsgWarn"    AutomationProperties.AutomationId="DlgMsgWarn"/>
                                <Button Content="MessageBox Error"   Width="140" Height="34" Margin="4" Click="OnMsgError"   AutomationProperties.AutomationId="DlgMsgError"/>
                                <Button Content="MessageBox Question" Width="140" Height="34" Margin="4" Click="OnMsgQuestion" AutomationProperties.AutomationId="DlgMsgQuestion"/>
                            </WrapPanel>
                        </GroupBox>

                        <GroupBox Header="Miscellaneous Controls" Margin="0,0,0,12">
                            <Grid Margin="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="160"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormLabel}" Text="Date picker:"/>
                                <DatePicker Grid.Row="0" Grid.Column="1" Margin="0,3" AutomationProperties.AutomationId="MiscDatePicker"/>
                                <TextBlock Grid.Row="0" Grid.Column="2" Style="{StaticResource FormLabel}" Text="Calendar:"/>
                                <Calendar Grid.Row="0" Grid.Column="3" Margin="0,3" SelectionMode="SingleDate" AutomationProperties.AutomationId="MiscCalendar"/>

                                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FormLabel}" Text="Editable ComboBox:"/>
                                <ComboBox  Grid.Row="1" Grid.Column="1" IsEditable="True" Text="Custom value" Margin="0,3" AutomationProperties.AutomationId="MiscEditCombo">
                                    <ComboBoxItem>Option A</ComboBoxItem>
                                    <ComboBoxItem>Option B</ComboBoxItem>
                                    <ComboBoxItem>Option C</ComboBoxItem>
                                </ComboBox>
                                <TextBlock Grid.Row="1" Grid.Column="2" Style="{StaticResource FormLabel}" Text="Multiline TextBox:"/>
                                <TextBox   Grid.Row="1" Grid.Column="3" Height="60" TextWrapping="Wrap"
                                           AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                                           Text="Line one&#x0a;Line two&#x0a;Line three"
                                           Margin="0,3" AutomationProperties.AutomationId="MiscMultilineTextBox"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FormLabel}" Text="Separator:"/>
                                <Separator Grid.Row="2" Grid.Column="1" Margin="0,6"/>

                                <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FormLabel}" Text="Slider (vertical):"/>
                                <Slider    Grid.Row="3" Grid.Column="1" Orientation="Vertical" Height="80"
                                           Minimum="0" Maximum="100" Value="60"
                                           TickFrequency="10" TickPlacement="BottomRight"
                                           HorizontalAlignment="Left" Margin="0,3"
                                           AutomationProperties.AutomationId="MiscVertSlider"/>
                                <TextBlock Grid.Row="3" Grid.Column="2" Style="{StaticResource FormLabel}" Text="Radio group:"/>
                                <StackPanel Grid.Row="3" Grid.Column="3" Margin="0,3">
                                    <RadioButton Content="Choice Alpha"   GroupName="MiscGroup" IsChecked="True" Margin="0,2" AutomationProperties.AutomationId="MiscRadioA"/>
                                    <RadioButton Content="Choice Beta"    GroupName="MiscGroup" Margin="0,2" AutomationProperties.AutomationId="MiscRadioB"/>
                                    <RadioButton Content="Choice Gamma"   GroupName="MiscGroup" Margin="0,2" AutomationProperties.AutomationId="MiscRadioC"/>
                                    <RadioButton Content="Choice Delta"   GroupName="MiscGroup" Margin="0,2" AutomationProperties.AutomationId="MiscRadioD"/>
                                </StackPanel>

                                <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource FormLabel}" Text="ListBox (multi):"/>
                                <ListBox   Grid.Row="4" Grid.Column="1" Height="90" SelectionMode="Multiple" Margin="0,3"
                                           AutomationProperties.AutomationId="MiscMultiListBox">
                                    <ListBoxItem>Apple</ListBoxItem>
                                    <ListBoxItem>Banana</ListBoxItem>
                                    <ListBoxItem>Cherry</ListBoxItem>
                                    <ListBoxItem>Date</ListBoxItem>
                                    <ListBoxItem>Elderberry</ListBoxItem>
                                </ListBox>
                                <TextBlock Grid.Row="4" Grid.Column="2" Style="{StaticResource FormLabel}" Text="FlowDocument:"/>
                                <FlowDocumentScrollViewer Grid.Row="4" Grid.Column="3" Height="90" Margin="0,3"
                                                          AutomationProperties.AutomationId="MiscFlowDoc">
                                    <FlowDocument>
                                        <Paragraph FontWeight="Bold">FlowDocument Viewer</Paragraph>
                                        <Paragraph>Supports <Bold>bold</Bold>, <Italic>italic</Italic>, and <Hyperlink>hyperlinks</Hyperlink>.</Paragraph>
                                        <List>
                                            <ListItem><Paragraph>Bullet one</Paragraph></ListItem>
                                            <ListItem><Paragraph>Bullet two</Paragraph></ListItem>
                                        </List>
                                    </FlowDocument>
                                </FlowDocumentScrollViewer>
                            </Grid>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
